#!/usr/bin/env python3
from __future__ import annotations

import runpy
import sys
from pathlib import Path


def main() -> None:
    start_script = Path(__file__).resolve().with_name("start.sh")
    sys.argv = [str(start_script), "--app", "pipeliner", *sys.argv[1:]]
    runpy.run_path(str(start_script), run_name="__main__")


if __name__ == "__main__":
    main()
